
pub fn eq_confidential1(a: Confidential1, b: Confidential1) -> bool {
    let a_i: (u1, u256) = <(u1, u256)>::into(a);
    let b_i: (u1, u256) = <(u1, u256)>::into(b);
    let (a_i_fst, a_i_snd): (u1, u256) = <(u1, u256)>::into(a_i);
    let (b_i_fst, b_i_snd): (u1, u256) = <(u1, u256)>::into(b_i);
    match jet::eq_1(a_i_fst, b_i_fst) {
        true => eq_256(a_i_snd, b_i_snd),
        false => false,
    }
}

pub fn eq_point(a: Point, b: Point) -> bool {
    let a_i: (u1, u256) = <(u1, u256)>::into(a);
    let b_i: (u1, u256) = <(u1, u256)>::into(b);
    let (a_i_fst, a_i_snd): (u1, u256) = <(u1, u256)>::into(a_i);
    let (b_i_fst, b_i_snd): (u1, u256) = <(u1, u256)>::into(b_i);
    match jet::eq_1(a_i_fst, b_i_fst) {
        true => eq_256(a_i_snd, b_i_snd),
        false => false,
    }
}

pub fn eq_ge(a: Ge, b: Ge) -> bool {
    let a_i: (u256, u256) = <(u256, u256)>::into(a);
    let b_i: (u256, u256) = <(u256, u256)>::into(b);
    let (a_i_fst, a_i_snd): (u256, u256) = <(u256, u256)>::into(a_i);
    let (b_i_fst, b_i_snd): (u256, u256) = <(u256, u256)>::into(b_i);
    match eq_256(a_i_fst, b_i_fst) {
        true => eq_256(a_i_snd, b_i_snd),
        false => false,
    }
}

pub fn eq_outpoint(a: Outpoint, b: Outpoint) -> bool {
    let a_i: (u256, u32) = <(u256, u32)>::into(a);
    let b_i: (u256, u32) = <(u256, u32)>::into(b);
    let (a_i_fst, a_i_snd): (u256, u32) = <(u256, u32)>::into(a_i);
    let (b_i_fst, b_i_snd): (u256, u32) = <(u256, u32)>::into(b_i);
    match eq_256(a_i_fst, b_i_fst) {
        true => eq_32(a_i_snd, b_i_snd),
        false => false,
    }
}

pub fn eq_gej(a: Gej, b: Gej) -> bool {
    let a_i: (Ge, u256) = <(Ge, u256)>::into(a);
    let b_i: (Ge, u256) = <(Ge, u256)>::into(b);
    let (a_i_fst, a_i_snd): (Ge, u256) = <(Ge, u256)>::into(a_i);
    let (b_i_fst, b_i_snd): (Ge, u256) = <(Ge, u256)>::into(b_i);
    match eq_Ge(a_i_fst, b_i_fst) {
        true => eq_256(a_i_snd, b_i_snd),
        false => false,
    }
}

pub fn eq_amount1(a: Amount1, b: Amount1) -> bool {
    let a_i: Either<Point, u64> = <Either<Point, u64>>::into(a);
    let b_i: Either<Point, u64> = <Either<Point, u64>>::into(b);
    match a_i {
        Left(a_i_i: Point) => match b_i {
            Left(b_i_i: Point) => eq_Point(a_i_i, b_i_i),
            Right(_: u64) => false,
        },
        Right(a_i_i: u64) => match b_i {
            Right(b_i_i: u64) => eq_64(a_i_i, b_i_i),
            Left(_: Point) => false,
        },
    }
}

pub fn eq_asset1(a: Asset1, b: Asset1) -> bool {
    let a_i: Either<Point, u256> = <Either<Point, u256>>::into(a);
    let b_i: Either<Point, u256> = <Either<Point, u256>>::into(b);
    match a_i {
        Left(a_i_i: Point) => match b_i {
            Left(b_i_i: Point) => eq_Point(a_i_i, b_i_i),
            Right(_: u256) => false,
        },
        Right(a_i_i: u256) => match b_i {
            Right(b_i_i: u256) => eq_256(a_i_i, b_i_i),
            Left(_: Point) => false,
        },
    }
}

