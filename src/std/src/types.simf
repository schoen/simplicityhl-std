    let a_i: Either<Point, u256> = <Either<Point, u256>>::into(a);
    let b_i: Either<Point, u256> = <Either<Point, u256>>::into(b);
    match a_i {
        Left(a_i_i: Point) => match b_i {
            Left(b_i_i: Point) => eq_Point(a_i_i, b_i_i),
            Right(_: u256) => false,
        },
        Right(a_i_i: u256) => match b_i {
            Right(b_i_i: u256) => eq_256(a_i_i, b_i_i),
            Left(_: Point) => false,
        },
    }
}

pub fn eq_token_amount1(a: TokenAmount1, b: TokenAmount1) -> bool {
    let a_i: Either<Point, u64> = <Either<Point, u64>>::into(a);
    let b_i: Either<Point, u64> = <Either<Point, u64>>::into(b);
    match a_i {
        Left(a_i_i: Point) => match b_i {
            Left(b_i_i: Point) => eq_Point(a_i_i, b_i_i),
            Right(_: u64) => false,
        },
        Right(a_i_i: u64) => match b_i {
            Right(b_i_i: u64) => eq_64(a_i_i, b_i_i),
            Left(_: Point) => false,
        },
    }
}

pub fn eq_distance(a: Distance, b: Distance) -> bool {
    let a_i: u16 = <u16>::into(a);
    let b_i: u16 = <u16>::into(b);
    eq_16(a_i, b_i)
}

pub fn eq_duration(a: Duration, b: Duration) -> bool {
    let a_i: u16 = <u16>::into(a);
    let b_i: u16 = <u16>::into(b);
    eq_16(a_i, b_i)
}

pub fn eq_explicit_amount(a: ExplicitAmount, b: ExplicitAmount) -> bool {
    let a_i: u64 = <u64>::into(a);
    let b_i: u64 = <u64>::into(b);
    eq_64(a_i, b_i)
}

pub fn eq_explicit_asset(a: ExplicitAsset, b: ExplicitAsset) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_explicit_nonce(a: ExplicitNonce, b: ExplicitNonce) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_fe(a: Fe, b: Fe) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_height(a: Height, b: Height) -> bool {
    let a_i: u32 = <u32>::into(a);
    let b_i: u32 = <u32>::into(b);
    eq_32(a_i, b_i)
}

pub fn eq_lock(a: Lock, b: Lock) -> bool {
    let a_i: u32 = <u32>::into(a);
    let b_i: u32 = <u32>::into(b);
    eq_32(a_i, b_i)
}

pub fn eq_message(a: Message, b: Message) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_message64(a: Message64, b: Message64) -> bool {
    let a_i: [u8; 64] = <[u8; 64]>::into(a);
    let b_i: [u8; 64] = <[u8; 64]>::into(b);
    let (a_i_hi, a_i_lo): (u256, u256) = <[u8; 64]>::into(a_i);
    let (b_i_hi, b_i_lo): (u256, u256) = <[u8; 64]>::into(b_i);
    match eq_256(a_i_hi, b_i_hi) {
        true => eq_256(a_i_lo, b_i_lo),
        false => false,
    }
}

pub fn eq_pubkey(a: Pubkey, b: Pubkey) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_scalar(a: Scalar, b: Scalar) -> bool {
    let a_i: u256 = <u256>::into(a);
    let b_i: u256 = <u256>::into(b);
    eq_256(a_i, b_i)
}

pub fn eq_signature(a: Signature, b: Signature) -> bool {
    let a_i: [u8; 64] = <[u8; 64]>::into(a);
    let b_i: [u8; 64] = <[u8; 64]>::into(b);
    let (a_i_hi, a_i_lo): (u256, u256) = <[u8; 64]>::into(a_i);
    let (b_i_hi, b_i_lo): (u256, u256) = <[u8; 64]>::into(b_i);
    match eq_256(a_i_hi, b_i_hi) {
        true => eq_256(a_i_lo, b_i_lo),
        false => false,
    }
}

pub fn eq_time(a: Time, b: Time) -> bool {
    let a_i: u32 = <u32>::into(a);
    let b_i: u32 = <u32>::into(b);
    eq_32(a_i, b_i)
}


pub fn assert_eq_confidential1(a: Confidential1, b: Confidential1) {
    assert!(eq_confidential1(a, b));
}

pub fn assert_eq_point(a: Point, b: Point) {
    assert!(eq_point(a, b));
}

